enum Role {
  USER
  ADMIN
}

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  name          String?
  emailVerified Boolean @default(false) @map("email_verified")
  image         String?
  role          Role    @default(USER)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions             Session[]
  accounts             Account[]
  carts                Cart[]
  productSubscriptions ProductSubscription[]
  favoriteProducts     FavoriteProduct[]
  reviews              Review[]
  shopQuestions        ShopQuestion[]
  orders               Order[]
  shopAnswers          ShopAnswer[]
  reviewAnswers        ReviewAnswer[]

  @@map("user")
}

model Session {
  id        String  @id @default(cuid())
  token     String  @unique
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("session")
}

model Account {
  id           String  @id @default(cuid())
  accountId    String  @map("account_id")
  providerId   String  @map("provider_id")
  userId       String  @map("user_id")
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String? @map("access_token")
  refreshToken String? @map("refresh_token")
  idToken      String? @map("id_token")
  scope        String?
  password     String?

  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("account")
}

model Verification {
  id         String @id @default(cuid())
  identifier String
  value      String

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("verification")
}

model Cart {
  id     Int    @id @default(autoincrement())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cartItems CartItem[]

  @@map("cart")
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    Int     @map("cart_id")
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([cartId, productId])
  @@map("cart_item")
}

model ShopQuestion {
  id      Int    @id @default(autoincrement())
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title   String
  comment String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shopQuestionImages ShopQuestionImage[]
  shopAnswers        ShopAnswer[]

  @@index([userId])
  @@map("shop_question")
}

model ShopQuestionImage {
  id             Int          @id @default(autoincrement())
  shopQuestionId Int          @map("shop_question_id")
  shopQuestion   ShopQuestion @relation(fields: [shopQuestionId], references: [id], onDelete: Cascade)
  url            String

  @@index([shopQuestionId])
  @@map("shop_question_image")
}

model ShopAnswer {
  id             Int          @id @default(autoincrement())
  shopQuestionId Int          @map("shop_question_id")
  shopQuestion   ShopQuestion @relation(fields: [shopQuestionId], references: [id], onDelete: Cascade)
  comment        String
  userId         String?      @map("user_id")
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([shopQuestionId])
  @@map("shop_answer")
}

enum ObtainingMethod {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  NEW
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

model Order {
  id              Int             @id @default(autoincrement())
  userId          String?         @map("user_id")
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  obtainingMethod ObtainingMethod @map("obtaining_method")
  orderStatus     OrderStatus     @default(NEW) @map("order_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orderItems OrderItem[]
  delivery   Delivery?
  payment    Payment?

  @@index([userId])
  @@index([orderStatus, createdAt])
  @@index([createdAt])
  @@map("order")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  price     Decimal @db.Decimal(12, 2)
  quantity  Int

  @@unique([orderId, productId])
  @@index([productId])
  @@map("order_item")
}

enum DeliveryMethod {
  OZON
}

model Delivery {
  id             Int            @id @default(autoincrement())
  orderId        Int            @unique @map("order_id")
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  address        String
  apartment      String?
  entrance       String?
  floor          String?
  intercom       String?
  comment        String?
  deliveryMethod DeliveryMethod @default(OZON) @map("delivery_method")

  deliveredAt DateTime? @map("delivered_at")

  @@index([orderId])
  @@map("delivery")
}

enum PaymentMethod {
  OFFLINE
  ONLINE
}

model Payment {
  id            Int           @id @default(autoincrement())
  orderId       Int           @unique @map("order_id")
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @map("payment_method")
  amount        Decimal       @db.Decimal(12, 2)
  transactionId String?       @map("transaction_id")

  paidAt DateTime @default(now()) @map("paid_at")

  @@index([orderId])
  @@map("payment")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  products Product[]

  @@map("category")
}

model Product {
  id           Int      @id @default(autoincrement())
  name         String
  description  String
  currentPrice Decimal  @map("current_price") @db.Decimal(12, 2)
  oldPrice     Decimal  @map("old_price") @db.Decimal(12, 2)
  article      String   @unique
  mainImage    String   @map("main_image")
  ozonLink     String?  @map("ozon_link")
  categoryId   Int      @map("category_id")
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  isActive     Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productImages        ProductImage[]
  productPrices        ProductPrice[]
  productStocks        ProductStock[]
  productAttributes    ProductAttribute[]
  productSubscriptions ProductSubscription[]
  favoriteProducts     FavoriteProduct[]
  cartItems            CartItem[]
  reviews              Review[]
  orderItems           OrderItem[]

  @@index([categoryId, isActive])
  @@map("product")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String

  @@index([productId])
  @@map("product_image")
}

model ProductPrice {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  value     Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId, createdAt(sort: Desc)])
  @@map("product_price")
}

model ProductStock {
  id        Int     @id @default(autoincrement())
  productId Int     @unique @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(0)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_stock")
}

model Attribute {
  id   Int     @id @default(autoincrement())
  name String
  unit String?

  productAttributes ProductAttribute[]

  @@unique([name, unit])
  @@map("attribute")
}

model ProductAttribute {
  id          Int       @id @default(autoincrement())
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeId Int       @map("attribute_id")
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String

  @@unique([productId, attributeId])
  @@index([attributeId, value])
  @@map("product_attribute")
}

model ProductSubscription {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@index([productId])
  @@map("product_subscription")
}

model FavoriteProduct {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@index([productId])
  @@map("favorite_product")
}

model Review {
  id            Int     @id @default(autoincrement())
  userId        String  @map("user_id")
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     Int     @map("product_id")
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating        Int
  advantages    String?
  disadvantages String?
  comment       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reviewPhotos  ReviewPhoto[]
  reviewAnswers ReviewAnswer[]

  @@unique([userId, productId])
  @@index([productId])
  @@map("review")
}

model ReviewPhoto {
  id       Int    @id @default(autoincrement())
  reviewId Int    @map("review_id")
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url      String

  @@index([reviewId])
  @@map("review_photo")
}

model ReviewAnswer {
  id       Int     @id @default(autoincrement())
  reviewId Int     @map("review_id")
  review   Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  text     String
  userId   String? @map("user_id")
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([reviewId])
  @@map("review_answer")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
