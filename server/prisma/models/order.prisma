enum ObtainingMethod {
    DELIVERY
    PICKUP
}

enum OrderStatus {
    NEW
    CONFIRMED
    PROCESSING
    SHIPPED
    COMPLETED
    CANCELLED
}

enum PaymentMethod {
    OFFLINE
    ONLINE
}

model Order {
    id              Int             @id @default(autoincrement())
    userId          String?         @map("user_id")
    user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
    obtainingMethod ObtainingMethod @map("obtaining_method")
    orderStatus     OrderStatus     @default(NEW) @map("order_status")
    paymentMethod   PaymentMethod   @map("payment_method")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    orderItems OrderItem[]
    delivery   Delivery?
    payment    Payment?

    @@index([userId])
    @@index([orderStatus, createdAt])
    @@index([createdAt])
    @@map("order")
}

model OrderItem {
    id        Int     @id @default(autoincrement())
    orderId   Int     @map("order_id")
    order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
    productId Int     @map("product_id")
    product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
    price     Decimal @db.Decimal(12, 2)
    quantity  Int

    @@unique([orderId, productId])
    @@index([productId])
    @@map("order_item")
}

enum DeliveryMethod {
    OZON
}

model Delivery {
    id             Int            @id @default(autoincrement())
    orderId        Int            @unique @map("order_id")
    order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
    address        String
    apartment      String?
    entrance       String?
    floor          String?
    intercom       String?
    comment        String?
    deliveryMethod DeliveryMethod @default(OZON) @map("delivery_method")

    deliveredAt DateTime? @map("delivered_at")

    @@index([orderId])
    @@map("delivery")
}

enum PaymentStatus {
    UPON_RECEIPT
    PAID
}

model Payment {
    id            Int           @id @default(autoincrement())
    orderId       Int           @unique @map("order_id")
    order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
    paymentStatus PaymentStatus @map("payment_status")
    amount        Decimal       @db.Decimal(12, 2)
    transactionId String?       @map("transaction_id")

    paidAt DateTime? @map("paid_at")

    @@index([orderId])
    @@map("payment")
}
